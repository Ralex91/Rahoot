{
  "name": "rahoot",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "dev:socket": "dotenv -e .env -- pnpm --filter socket dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "pnpm -r --parallel run lint",
    "format": "pnpm -r --parallel run format",
    "format:fix": "pnpm -r --parallel run format:fix"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.3"
  }
}
